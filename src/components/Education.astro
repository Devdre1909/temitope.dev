---
const education = [
  {
    degree: "B.Tech, Information Technology",
    school: "Federal University of Technology Akure (FUTA)",
    period: "2024",
    description:
      "Studied Information Technology with focus on software engineering and systems design. Applied technical skills through building real-world applications throughout the program.",
    tags: ["Information Technology", "Software Engineering", "Systems Design"],
    current: false,
  },
];
---

<section class="py-24 max-w-6xl mx-auto px-6" id="education">
  <h2 class="text-3xl font-bold text-white mb-12" data-reveal>Education</h2>
  <div class="space-y-8">
    {
      education.map((item) => (
        <div class="group relative pl-8 border-l border-gray-800" data-reveal>
          <span class="absolute -left-[5px] top-2 h-2.5 w-2.5 rounded-full ring-4 ring-bg-dark bg-gray-600 group-hover:bg-indigo-500 transition-colors" />
          <div class="flex flex-col md:flex-row md:items-center justify-between mb-2">
            <h3 class="text-xl font-bold text-white">{item.degree}</h3>
            <span class="text-sm font-mono text-gray-500 bg-bg-card px-3 py-1 rounded-full">
              {item.period}
            </span>
          </div>
          <div class="text-gray-400 group-hover:text-indigo-400 transition-colors font-medium mb-4">
            {item.school}
          </div>
          <p class="text-gray-400 max-w-3xl mb-4">{item.description}</p>
          <div class="flex flex-wrap gap-2">
            {item.tags.map((tag) => (
              <span class="text-xs bg-gray-800 text-gray-300 px-2 py-1 rounded">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
