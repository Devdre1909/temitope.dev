---

<section class="py-24 max-w-6xl mx-auto px-6" id="experience">
  <h2 class="text-3xl font-bold text-white mb-12">Work Experience</h2>
  <div class="space-y-8">
    {jobs.map((job) => (
      <div class="group relative pl-8 border-l border-gray-800">
        <span
          class={`absolute -left-[5px] top-2 h-2.5 w-2.5 rounded-full ring-4 ring-bg-dark ${
            job.current
              ? "bg-indigo-500"
              : "bg-gray-600 group-hover:bg-indigo-500 transition-colors"
          }`}
        />
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-2">
          <h3 class="text-xl font-bold text-white">{job.title}</h3>
          <span class="text-sm font-mono text-gray-500 bg-bg-card px-3 py-1 rounded-full">
            {job.period}
          </span>
        </div>
        <div
          class={`font-medium mb-4 ${
            job.current
              ? "text-indigo-400"
              : "text-gray-400 group-hover:text-indigo-400 transition-colors"
          }`}
        >
          {job.companyUrl ? (
            <a href={job.companyUrl} target="_blank" rel="noopener noreferrer" class="hover:underline">
              {job.company}
            </a>
          ) : (
            job.company
          )}
        </div>
        <p class="text-gray-400 max-w-3xl mb-4">{job.description}</p>
        <div class="flex flex-wrap gap-2">
          {job.tags.map((tag) => (
            <span class="text-xs bg-gray-800 text-gray-300 px-2 py-1 rounded">
              {tag}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
