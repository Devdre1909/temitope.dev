---
const stats = [
  { value: "6+", label: "Years Experience" },
  { value: "40+", label: "Projects Completed" },
];
---

<section class="py-24 bg-bg-alt" id="about">
  <div class="max-w-6xl mx-auto px-6">
    <h2
      class="text-sm font-bold tracking-widest text-indigo-400 uppercase mb-3"
    >
      About Me
    </h2>
    <h3 class="text-3xl font-bold text-white mb-6">
      Building the web, one component at a time.
    </h3>
    <div class="space-y-4 text-gray-400 text-lg leading-relaxed max-w-3xl">
      <p>
        With over 6 years of experience in full-stack development, I specialize
        in building performant web and mobile applications using React, React
        Native, Node.js, and TypeScript. My work spans fintech, education,
        and e-commerce — delivering platforms that serve thousands of users.
      </p>
      <p>
        Currently, I'm building products at
        <span class="text-white font-medium">Pika Insights</span>, where I lead
        development of mobile and web solutions for sales and inventory
        management. I'm also recognized for open-source contributions like
        Dotenv Intellisense, a popular VS Code extension.
      </p>
    </div>
    <div class="mt-8 flex gap-6">
      {stats.map((stat) => (
        <div>
          <span class="block text-3xl font-bold text-white">{stat.value}</span>
          <span class="text-sm text-gray-500">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
