---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Request Data Removal — Numvs"
  description="Submit a request to have your personal data removed from Numvs."
>
  <main class="min-h-screen flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-lg">
      <!-- Header -->
      <div class="mb-10 text-center">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 mb-5">
          <svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-white tracking-tight">Request Data Removal</h1>
        <p class="mt-2 text-sm text-gray-400">
          Fill in the form below and we'll process your request. A confirmation will be sent to your email.
        </p>
      </div>

      <!-- Form card -->
      <div
        id="form-card"
        class="bg-[#1E1E1E] border border-white/5 rounded-2xl p-8 shadow-xl"
      >
        <form id="removal-form" novalidate>
          <!-- Email -->
          <div class="mb-6">
            <label for="email" class="block text-sm font-medium text-gray-300 mb-2">
              Email address <span class="text-red-400">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="you@example.com"
              class="w-full bg-[#121212] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-600 outline-none focus:border-indigo-500/60 focus:ring-2 focus:ring-indigo-500/20 transition"
            />
            <p id="email-error" class="mt-1.5 text-xs text-red-400 hidden">Please enter a valid email address.</p>
          </div>

          <!-- Reason -->
          <div class="mb-8">
            <label for="reason" class="block text-sm font-medium text-gray-300 mb-2">
              Reason for removal <span class="text-red-400">*</span>
            </label>
            <textarea
              id="reason"
              name="reason"
              required
              rows="4"
              placeholder="Please briefly describe why you'd like your data removed..."
              class="w-full bg-[#121212] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-600 outline-none focus:border-indigo-500/60 focus:ring-2 focus:ring-indigo-500/20 transition resize-none"
            ></textarea>
            <p id="reason-error" class="mt-1.5 text-xs text-red-400 hidden">Please provide a reason.</p>
          </div>

          <!-- Error banner -->
          <div id="submit-error" class="hidden mb-5 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/20 text-sm text-red-400">
            Something went wrong. Please try again or contact us directly.
          </div>

          <!-- Submit -->
          <button
            id="submit-btn"
            type="submit"
            class="w-full bg-indigo-600 hover:bg-indigo-500 disabled:opacity-60 disabled:cursor-not-allowed text-white text-sm font-semibold rounded-xl px-6 py-3 transition-colors flex items-center justify-center gap-2"
          >
            <span id="btn-text">Submit Request</span>
            <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4l3-3-3-3v4a8 8 0 00-8 8h4z"></path>
            </svg>
          </button>
        </form>
      </div>

      <!-- Success state (hidden by default) -->
      <div
        id="success-card"
        class="hidden bg-[#1E1E1E] border border-white/5 rounded-2xl p-10 shadow-xl text-center"
      >
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-green-500/10 border border-green-500/20 mb-5">
          <svg class="w-7 h-7 text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-white mb-2">Request Received</h2>
        <p class="text-sm text-gray-400 leading-relaxed">
          We've received your data removal request and sent a confirmation to your email.<br />
          We'll process it within <span class="text-white font-medium">7 business days</span>.
        </p>
      </div>

      <!-- Footer note -->
      <p class="mt-6 text-center text-xs text-gray-600">
        Having trouble? Email us at
        <a href="mailto:hi@temitope.dev" class="text-indigo-400 hover:text-indigo-300 transition-colors">hi@temitope.dev</a>
      </p>
    </div>
  </main>
</Layout>

<script>
  const FORMSPREE_ENDPOINT = "https://formspree.io/f/YOUR_FORM_ID"; // Replace YOUR_FORM_ID

  const form = document.getElementById("removal-form") as HTMLFormElement;
  const formCard = document.getElementById("form-card")!;
  const successCard = document.getElementById("success-card")!;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = document.getElementById("btn-text")!;
  const btnSpinner = document.getElementById("btn-spinner")!;
  const submitError = document.getElementById("submit-error")!;
  const emailInput = document.getElementById("email") as HTMLInputElement;
  const reasonInput = document.getElementById("reason") as HTMLTextAreaElement;
  const emailError = document.getElementById("email-error")!;
  const reasonError = document.getElementById("reason-error")!;

  function validate(): boolean {
    let valid = true;
    emailError.classList.add("hidden");
    reasonError.classList.add("hidden");

    if (!emailInput.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value)) {
      emailError.classList.remove("hidden");
      valid = false;
    }
    if (!reasonInput.value.trim()) {
      reasonError.classList.remove("hidden");
      valid = false;
    }
    return valid;
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!validate()) return;

    submitBtn.disabled = true;
    btnText.textContent = "Submitting…";
    btnSpinner.classList.remove("hidden");
    submitError.classList.add("hidden");

    try {
      const res = await fetch(FORMSPREE_ENDPOINT, {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify({
          email: emailInput.value,
          reason: reasonInput.value,
          _replyto: emailInput.value,
          _subject: "Data Removal Request — Numvs",
        }),
      });

      if (res.ok) {
        formCard.classList.add("hidden");
        successCard.classList.remove("hidden");
      } else {
        throw new Error("Non-OK response");
      }
    } catch {
      submitError.classList.remove("hidden");
      submitBtn.disabled = false;
      btnText.textContent = "Submit Request";
      btnSpinner.classList.add("hidden");
    }
  });
</script>
